NODE_ENV=development
PORT=5000

# Database
# Leave blank to use your own MongoDB URI or the development fallback path.
MONGO_URI=

# Authentication
JWT_SECRET=replace_with_a_long_random_secret

# CORS
# Comma-separated extra origins. Same-origin Render traffic requires no entry.
CLIENT_ORIGINS=http://localhost:4200

# AI and media providers
UNSPLASH_ACCESS_KEY=
GEMINI_API_KEY=

# Future map provider placeholder
MAPBOX_TOKEN=
